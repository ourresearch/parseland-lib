        {  # bot-check in gold | harvest UUID: de73d3e8-3f51-40af-9933-df4ae7d197d7
            "doi": "10.1016/j.clpl.2024.100067",
            "result": {
                "authors": [
                    {
                        "name": "Giulia Alessandri",
